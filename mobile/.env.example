# Copia este archivo a mobile/.env y completa con los valores de tu proyecto Supabase
# (Supabase Dashboard → Project Settings → API)
EXPO_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key

# Client ID de Google OAuth (NO es secreto, puede ir en la app).
# Es el mismo "Aplicación web" que creaste en Google Cloud Console.
EXPO_PUBLIC_GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
